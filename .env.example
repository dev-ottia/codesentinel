# ─────────────────────────────────────────────────────────────────────────────
# CodeSentinel — Environment Variables Example
# Copy this file to .env and fill in your values.
# NEVER commit the real .env file to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
DB_USER=codesentinel
DB_PASSWORD=changeme
DB_NAME=codesentinel
DATABASE_URL=postgresql+asyncpg://codesentinel:changeme@postgres:5432/codesentinel

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Ollama (local AI) ─────────────────────────────────────────────────────────
# Install from https://ollama.com then run: ollama pull qwen2.5:3b
OLLAMA_URL=http://host.docker.internal:11434
OLLAMA_MODEL=qwen2.5:3b

# ── GitHub App ────────────────────────────────────────────────────────────────
# Set up a webhook at: GitHub repo → Settings → Webhooks → Add webhook
# Use any random string as the secret, paste it here and in GitHub UI
GITHUB_APP_WEBHOOK_SECRET=your_webhook_secret_here

# Optional — GitHub App OAuth (for future auth feature)
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=

# GitHub Personal Access Token — needed to fetch PR diffs
# Create at: https://github.com/settings/tokens/new
# Required scopes: public_repo (public repos) or repo (private repos)
GITHUB_TOKEN=ghp_your_token_here

# ── Application ───────────────────────────────────────────────────────────────
# Generate a strong random key: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your_random_secret_key_here

LOG_LEVEL=INFO
# "console" = coloured dev output | "json" = structured production output
LOG_FORMAT=json

# Comma-separated allowed CORS origins
CORS_ORIGINS=http://localhost:3000

# Diff cache TTL in seconds (default: 2 hours)
DIFF_CACHE_TTL=7200
